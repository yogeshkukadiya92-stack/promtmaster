# Server-only. Never prefix these with VITE_ and never expose them to browser code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Optional server-side Supabase persistence. Keep the service-role key private.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Preferred Railway persistence. Railway's MongoDB service supplies MONGODB_URI.
MONGODB_URI=
MONGODB_DATABASE=intentos
# Required for signed private-device sessions on MongoDB deployments (32+ characters).
AUTH_SECRET=
# Required to enable the protected Auth & Data Control panel (24+ characters).
ADMIN_ACCESS_KEY=

# Separate execution worker identity and queue polling interval.
AGENT_WORKER_NAME=intentos-worker-1
AGENT_WORKER_POLL_MS=1500
AGENT_WORKER_LEASE_SECONDS=60
AGENT_TOOL_TIMEOUT_MS=8000
# Exact HTTPS hostnames only, comma-separated. Empty means all outbound HTTP tool calls are blocked.
AGENT_HTTP_ALLOWLIST=

# Public browser configuration. These values are safe to expose; never place the service-role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Set to mongodb when deploying with the MongoDB repository.
VITE_AUTH_MODE=

API_PORT=8787
APP_URL=http://localhost:4173

# Required for BYOK encryption in production. Generate a unique value of at least 32 characters.
ENTERPRISE_KEY_ENCRYPTION_SECRET=

# Server-only Stripe keys. Checkout uses API version 2026-02-25.clover.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional transactional email provider.
RESEND_API_KEY=
INVITE_EMAIL_FROM=IntentOS <noreply@example.com>

# Production smoke test target; used only by npm run smoke:production.
SMOKE_BASE_URL=http://127.0.0.1:8787
